# روی سیستم خودت (محلی) می‌تونی همچنان از SQLite استفاده کنی، ولی برای آنلاین‌کردن
# باید حتماً یک دیتابیس PostgreSQL بگیری (مثلاً از پنل لیارا) و آدرسش رو اینجا بذاری:
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ----- درگاه پرداخت زرین‌پال -----
# مرچنت آیدی که از پنل زرین‌پال (zarinpal.com) دریافت می‌کنی
ZARINPAL_MERCHANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# تا وقتی مرچنت آیدی واقعی نداری، این را روی true بگذار تا در حالت آزمایشی (sandbox) کار کند
# و پول واقعی جابه‌جا نشود. وقتی مرچنت آیدی واقعی گرفتی، این را false کن.
ZARINPAL_SANDBOX="true"

# آدرس سایتت. روی سیستم خودت همین مقدار را نگه دار.
# وقتی سایت را آنلاین کردی (روی یک دامنه واقعی)، این را به آدرس واقعی سایتت تغییر بده.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ----- ورود به پنل مدیریت -----
# نام کاربری و رمز عبوری که برای ورود به /admin استفاده می‌کنی. حتماً عوضش کن!
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="یک-رمز-قوی-اینجا-بذار"

# یک رشته‌ی تصادفی و طولانی و مخفی (هرچی دلت خواست بنویس، هرچه پیچیده‌تر بهتر)
AUTH_SECRET="یک-رشته-تصادفی-طولانی-اینجا-بذار-مثلا-x7k9m2p4q8w1z5r3"

# ----- پیامک کد تایید (OTP) با کاوه‌نگار -----
# از پنل kavenegar.com بگیر. اگر خالی بذاری، کد تایید در ترمینال چاپ می‌شود (حالت تست بدون هزینه)
KAVENEGAR_API_KEY=""
# نام الگوی (Template/Pattern) پیامکی که در پنل کاوه‌نگار برای ارسال کد تایید ساختی
KAVENEGAR_TEMPLATE="verify"

# شماره واتساپ پشتیبانی برای دکمه چت شناور (با کد کشور، بدون + و بدون صفر اول)
# مثال برای 09121234567 بنویس: 989121234567
NEXT_PUBLIC_WHATSAPP_NUMBER=""

DATABASE_URL (مثلاً file:./dev.db برای SQLite)
KAVENEGAR_API_KEY (فعلاً می‌تونی یه مقدار dummy بذاری)
KAVENEGAR_TEMPLATE
AUTH_SECRET
ADMIN_USERNAME, ADMIN_PASSWORD
ZARINPAL_MERCHANT_ID, ZARINPAL_SANDBOX, NEXT_PUBLIC_BASE_URL
